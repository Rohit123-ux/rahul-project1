{% extends 'base.html' %}
{% block title %}Result — HealthGuard{% endblock %}
{% block content %}
<div style="max-width:800px;margin:0 auto;">
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;">
  <h1 style="font-family:'DM Serif Display',serif;font-size:24px;">🩺 Your Health Assessment</h1>
  <div style="display:flex;gap:8px;">
    <a href="/download_report/{{ pred.id }}" class="btn btn-outline">📄 Download PDF</a>
    <a href="/predict" class="btn btn-primary">🔬 New Check</a>
  </div>
</div>

<!-- OVERALL SCORE -->
{% set sc = pred.overall_score %}
{% set scol = '#22c55e' if sc>=75 else '#f97316' if sc>=50 else '#ef4444' %}
<div class="card" style="margin-bottom:20px;border-color:{{ scol }}40;">
  <div style="display:flex;align-items:center;gap:20px;">
    <div style="font-family:'DM Serif Display',serif;font-size:52px;color:{{ scol }};line-height:1;">{{ sc }}</div>
    <div>
      <div style="font-size:11px;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;">Overall Health Score</div>
      <div style="font-size:20px;font-weight:700;color:{{ scol }};">{{ pred.overall_status }}</div>
      <div style="font-size:12px;color:var(--muted);margin-top:2px;">Out of 100 · {{ pred.created_at.strftime('%d %B %Y, %I:%M %p') }}</div>
    </div>
  </div>
</div>

<!-- 3 DISEASE CARDS -->
{% set diseases = [
  ('heart',    '❤️', 'Heart Disease',    'Cardiovascular Risk',   pred.heart_risk,    pred.heart_level,    result.heart.advice,    '#ff4d6d', 'prog-heart'),
  ('diabetes', '🩸', 'Diabetes',         'Blood Sugar Disorder',  pred.diabetes_risk, pred.diabetes_level, result.diabetes.advice, '#f59e0b', 'prog-diab'),
  ('kidney',   '🫘', 'Kidney Disease',   'Chronic Kidney Disease',pred.kidney_risk,   pred.kidney_level,   result.kidney.advice,   '#22d3ee', 'prog-kidney'),
] %}

{% for key, emoji, name, subtitle, risk, level, advice, color, pc in diseases %}
<div class="card" style="margin-bottom:16px;border-color:{{ color }}40;">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
    <div style="display:flex;align-items:center;gap:12px;">
      <div style="width:42px;height:42px;border-radius:12px;background:{{ color }}20;
        display:flex;align-items:center;justify-content:center;font-size:20px;">{{ emoji }}</div>
      <div>
        <div style="font-size:15px;font-weight:600;">{{ name }}</div>
        <div style="font-size:11px;color:var(--muted);">{{ subtitle }}</div>
      </div>
    </div>
    <span class="badge badge-{{ 'high' if 'High' in level else 'mod' if 'Moderate' in level else 'low' }}">{{ level }}</span>
  </div>
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
    <span style="font-size:12px;color:var(--muted);">Risk Probability</span>
    <span style="font-family:'DM Serif Display',serif;font-size:24px;color:{{ color }};">{{ risk|round(1) }}%</span>
  </div>
  <div class="prog-bg"><div class="prog-fill {{ pc }}" style="width:{{ risk }}%;transition:width 1.2s ease;"></div></div>
  <div style="margin-top:10px;background:var(--surface2);border-radius:8px;padding:10px 12px;
    font-size:12.5px;color:var(--muted);border-left:3px solid {{ color }};">{{ advice }}</div>
</div>
{% endfor %}

<a href="/dashboard" class="btn btn-outline btn-full" style="margin-top:8px;">← Back to Dashboard</a>
</div>
{% endblock %}
