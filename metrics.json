{% extends 'base.html' %}
{% block title %}HealthGuard — Multi Disease Risk Assessment{% endblock %}
{% block content %}
<style>
.hero{text-align:center;padding:80px 20px 60px;}
.hero h1{font-family:'DM Serif Display',serif;font-size:clamp(32px,5vw,52px);
  line-height:1.15;letter-spacing:-1px;margin-bottom:16px;}
.hero h1 em{font-style:italic;color:var(--accent);}
.hero p{color:var(--muted);font-size:16px;line-height:1.7;max-width:520px;margin:0 auto 32px;}
.pills{display:flex;justify-content:center;gap:10px;flex-wrap:wrap;margin-bottom:36px;}
.pill{padding:7px 18px;border-radius:100px;font-size:13px;font-weight:500;border:1px solid;}
.pill-h{background:rgba(255,77,109,.12);border-color:rgba(255,77,109,.3);color:var(--heart);}
.pill-d{background:rgba(245,158,11,.12);border-color:rgba(245,158,11,.3);color:var(--diabetes);}
.pill-k{background:rgba(34,211,238,.12);border-color:rgba(34,211,238,.3);color:var(--kidney);}
.hero-btns{display:flex;justify-content:center;gap:12px;}
.features{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px;margin-top:60px;}
.feat{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:24px;text-align:center;}
.feat-icon{font-size:32px;margin-bottom:12px;}
.feat h3{font-size:15px;font-weight:600;margin-bottom:8px;}
.feat p{font-size:13px;color:var(--muted);line-height:1.6;}
</style>

<div class="hero">
  <div style="display:inline-flex;align-items:center;gap:8px;background:var(--surface2);
    border:1px solid var(--border);border-radius:100px;padding:6px 16px;
    font-size:12px;color:var(--muted);margin-bottom:20px;">
    <span style="width:6px;height:6px;background:var(--green);border-radius:50%;"></span>
    ML-Powered Health Screening System
  </div>
  <h1>Predict <em>3 diseases</em><br/>from one health check</h1>
  <p>Enter your health parameters once and instantly assess your risk for Heart Disease, Diabetes, and Chronic Kidney Disease — powered by real hospital datasets.</p>
  <div class="pills">
    <div class="pill pill-h">❤️ Heart Disease</div>
    <div class="pill pill-d">🩸 Diabetes</div>
    <div class="pill pill-k">🫘 Kidney Disease</div>
  </div>
  <div class="hero-btns">
    <a href="/register" class="btn btn-primary">🚀 Get Started — Register</a>
    <a href="/login"    class="btn btn-outline">Login</a>
  </div>
</div>

<div class="features">
  <div class="feat">
    <div class="feat-icon">🔬</div>
    <h3>3 Diseases at Once</h3>
    <p>Fill one form and get simultaneous risk assessment for Heart Disease, Diabetes, and Kidney Disease.</p>
  </div>
  <div class="feat">
    <div class="feat-icon">📊</div>
    <h3>Risk Trend Charts</h3>
    <p>Track your health over time with interactive charts showing how your risk levels change each visit.</p>
  </div>
  <div class="feat">
    <div class="feat-icon">📄</div>
    <h3>Download PDF Report</h3>
    <p>Every health check generates a downloadable PDF report you can share with your doctor.</p>
  </div>
  <div class="feat">
    <div class="feat-icon">⚠️</div>
    <h3>Risk Alerts</h3>
    <p>Automatic alerts when your risk increases significantly — so you never miss a warning sign.</p>
  </div>
  <div class="feat">
    <div class="feat-icon">👨‍⚕️</div>
    <h3>Doctor Dashboard</h3>
    <p>Doctors can view all patients, filter by risk level, and monitor high-risk cases in real time.</p>
  </div>
  <div class="feat">
    <div class="feat-icon">🏥</div>
    <h3>Real Hospital Data</h3>
    <p>Models trained on Cleveland UCI, PIMA Indians, and Indian hospital datasets — 100% real data.</p>
  </div>
</div>

<div style="text-align:center;margin-top:60px;padding:40px;background:var(--surface);
  border:1px solid var(--border);border-radius:20px;">
  <p style="font-size:12px;color:var(--muted);margin-bottom:8px;">DOCTOR LOGIN</p>
  <p style="font-size:13px;color:var(--text);">Email: <code style="background:var(--surface2);padding:2px 8px;border-radius:4px;">doctor@healthguard.com</code>
  &nbsp;&nbsp;Password: <code style="background:var(--surface2);padding:2px 8px;border-radius:4px;">doctor123</code></p>
</div>
{% endblock %}
